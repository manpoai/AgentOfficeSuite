# ASuite Environment Variables
# Copy this file to .env and fill in your values
# Or run: node scripts/asuite-init.js --domain your-domain.com

# ─── Admin ─────────────────────────────────
ADMIN_EMAIL=admin@asuite.local
ADMIN_PASSWORD=changeme

# ─── Database Passwords (auto-generated by init script) ──
POSTGRES_MM_PASS=<auto-generated>
POSTGRES_PL_PASS=<auto-generated>
POSTGRES_BR_PASS=<auto-generated>
RABBITMQ_PASS=<auto-generated>

# ─── Service Secrets (auto-generated) ─────
MINIO_ACCESS_KEY=<auto-generated>
MINIO_SECRET_KEY=<auto-generated>
PLANE_SECRET_KEY=<auto-generated>

# ─── Gateway (filled after service setup) ──
MM_ADMIN_TOKEN=<from-mattermost-admin>
PLANE_TOKEN=<from-plane-api>
PLANE_WORKSPACE=asuite
PLANE_PROJECT_ID=<from-plane-project>
BASEROW_DATABASE_ID=<from-baserow>
GATEWAY_ADMIN_TOKEN=<auto-generated>

# ─── SSO / OIDC Secrets ──────────────────
MM_GITLAB_SECRET=<auto-generated>
SHELL_DEX_SECRET=<auto-generated>

# ─── Shell (public URLs for browser access) ─
# For local dev, use http://localhost:<port>
# For production, use your domain with https
SHELL_URL=http://localhost:3101
SHELL_SECRET=<auto-generated>
PUBLIC_MM_URL=http://localhost:8065
PUBLIC_PLANE_URL=http://localhost:8000
PUBLIC_BASEROW_URL=http://localhost:8280

# ─── Ports (host-side) ────────────────────
MM_PORT=8065
PLANE_PORT=8000
GATEWAY_PORT=4000
SHELL_PORT=3101
