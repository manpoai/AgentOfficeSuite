{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/utils/color": ["./src/editor-core/_stubs/shared-utils-color"],
      "@shared/utils/urls": ["./src/editor-core/_stubs/shared-utils-urls"],
      "@shared/utils/browser": ["./src/editor-core/_stubs/shared-utils-browser"],
      "@shared/utils/ProsemirrorHelper": ["./src/editor-core/_stubs/shared-utils-prosemirror-helper"],
      "@shared/utils/rfc6902": ["./src/editor-core/_stubs/shared-utils-rfc6902"],
      "@shared/editor/types": ["./src/editor-core/_stubs/shared-editor-types"],
      "~/editor": ["./src/editor-core/_stubs/editor-type"],
      "~/hooks/useDictionary": ["./src/editor-core/_stubs/use-dictionary"],
      "outline-icons": ["./src/editor-core/_stubs/outline-icons"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx"]
}
